<Window x:Class="CybersecurityBotGUI_part_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot" Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D1A"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Button Style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#7B2FBE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9B4FDE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#7B2FBE"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="172*"/>
            <ColumnDefinition Width="173*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#13132A" BorderBrush="#7B2FBE" BorderThickness="0,0,1,0">
            <StackPanel Margin="15">

                <!-- Logo Image -->
                <Image Source="cyber bot cybersecurity awareness.png" Height="180" Width="180" 
                       HorizontalAlignment="Center" Margin="0,20,0,10"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- ASCII Art as text -->
                <TextBlock Text="CYBER BOT" FontSize="20" FontWeight="Bold"
                           Foreground="#7B2FBE" HorizontalAlignment="Center"
                           FontFamily="Consolas" Margin="0,0,0,4"/>

                <TextBlock Text="Cybersecurity Awareness" FontSize="11"
                           Foreground="#888" HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Separator Background="#7B2FBE" Margin="0,0,0,20"/>

                <!-- User info panel -->
                <TextBlock Text="CURRENT USER" FontSize="10" Foreground="#888"
                           FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="SidebarUserName" Text="..." FontSize="14"
                           Foreground="White" FontWeight="Bold" Margin="0,0,0,20"/>

                <Separator Background="#333" Margin="0,0,0,20"/>

                <!-- Topics quick-access -->
                <TextBlock Text="QUICK TOPICS" FontSize="10" Foreground="#888"
                           FontWeight="Bold" Margin="0,0,0,10"/>

                <Button Content="🔑 Passwords" Style="{StaticResource SendButtonStyle}"
                        Margin="0,3" Click="QuickTopic_Click" Tag="password"/>
                <Button Content="🎣 Phishing" Style="{StaticResource SendButtonStyle}"
                        Margin="0,3" Click="QuickTopic_Click" Tag="phishing"
                        Background="#1A1A2E"/>
                <Button Content="🌐 Safe Browsing" Style="{StaticResource SendButtonStyle}"
                        Margin="0,3" Click="QuickTopic_Click" Tag="browsing"
                        Background="#1A1A2E"/>
                <Button Content="🏦 Banking Safety" Style="{StaticResource SendButtonStyle}"
                        Margin="0,3" Click="QuickTopic_Click" Tag="banking"
                        Background="#1A1A2E"/>
                <Button Content="🔐 2FA" Style="{StaticResource SendButtonStyle}"
                        Margin="0,3" Click="QuickTopic_Click" Tag="2fa"
                        Background="#1A1A2E"/>
            </StackPanel>
        </Border>

        <!-- MAIN CHAT AREA -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="#13132A" BorderBrush="#7B2FBE" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <Ellipse Width="12" Height="12" Fill="#00FF88" Margin="0,0,8,0"/>
                    <TextBlock Text="Cybersecurity Awareness Bot" FontSize="16"
                               FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Online &amp; Ready" FontSize="12"
                               Foreground="#888" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- NAME ENTRY PANEL (shown first, hidden after) -->
            <Border x:Name="NamePanel" Grid.Row="1" Background="#0D0D1A" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <TextBlock Text="👋 Welcome!" FontSize="28" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Please enter your name to get started:"
                               FontSize="14" Foreground="#AAA" HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <TextBox x:Name="NameInput" Style="{StaticResource InputBoxStyle}"
                             FontSize="16" Margin="0,0,0,15" Height="45"
                             KeyDown="NameInput_KeyDown"/>
                    <Button Content="Start Chatting!" Style="{StaticResource SendButtonStyle}"
                            Height="45" FontSize="15" Click="StartChat_Click"/>
                </StackPanel>
            </Border>

            <!-- CHAT PANEL (hidden until name entered) -->
            <ScrollViewer x:Name="ChatScroll" Grid.Row="1" 
                          Background="#0D0D1A" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="15">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>

            <!-- INPUT AREA -->
            <Border Grid.Row="2" Background="#13132A" BorderBrush="#7B2FBE" 
                    BorderThickness="0,1,0,0" Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UserInput" Grid.Column="0"
                             Style="{StaticResource InputBoxStyle}"
                             Height="44" Margin="0,0,10,0"
                             KeyDown="UserInput_KeyDown"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Content="Send 🚀"
                            Style="{StaticResource SendButtonStyle}"
                            Height="44" Click="SendButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>